# GPU metrics agent environment file
# Production: set AGENT_PSK and AGENT_SERVER_ID to match your report API server (see README.md).
# Local dev: copy to .env and edit.

# Upstream report API base URL (default http://localhost:8080)
# REPORT_API_URL=http://localhost:8080

# Agent pre-shared key (required for --push; must match server configuration)
# Derived per host (interactive; prompts for backend master secret):
#   AGENT_PSK=$(../../gsad-backend/deploy/scripts/derive-agent-psk.sh <AGENT_SERVER_ID>)
AGENT_PSK=replace-with-derived-psk-for-this-server

# Required. Server id (sent as JSON serverId on report API)
AGENT_SERVER_ID=gpu-node-01

# Resource label sent as resourceLevel (optional; omit to use first GPU name from nvidia-smi)
# AGENT_RESOURCE_LEVEL=NVIDIA RTX A6000

# Report interval (seconds)
AGENT_REPORT_INTERVAL=30

# Metrics HTTP server (--serve only; separate from health port)
# AGENT_HTTP_HOST=0.0.0.0
# AGENT_HTTP_PORT=9090

# Localhost health endpoint (0 = disabled)
AGENT_HEALTH_HOST=127.0.0.1
AGENT_HEALTH_PORT=9092
